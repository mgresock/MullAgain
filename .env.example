# ───────────────────────────────────────────────────────────────────────────
# MullAgain — environment variables
# Copy this file to `.env` and fill in real values.
# ───────────────────────────────────────────────────────────────────────────

# --- Core ---
# Postgres connection string used at runtime.
# Supabase + Vercel: use the POOLED connection (port 6543) and append
#   ?pgbouncer=true&connection_limit=1
# Local docker: postgresql://postgres:postgres@localhost:5432/mullagain?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mullagain?schema=public"
# Direct (non-pooled) connection used ONLY for migrations (prisma migrate/db push).
# Supabase: the port-5432 string. Locally you can reuse DATABASE_URL.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/mullagain?schema=public"

# Public base URL of the app (used for redirects, emails, Stripe return URLs).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Auth.js (NextAuth v5) ---
# Generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET="replace-with-a-long-random-string"
# Trust the host header in dev / behind a proxy.
AUTH_TRUST_HOST="true"
# Bearer token guarding /api/cron/maintenance (Vercel Cron sends it automatically).
CRON_SECRET=""

# --- Stripe (test mode) ---
# Dashboard → Developers → API keys
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# From `stripe listen` or the Dashboard webhook endpoint signing secret.
STRIPE_WEBHOOK_SECRET="whsec_..."
# Platform commission in basis points (800 = 8.00%).
PLATFORM_FEE_BPS="800"

# --- AWS S3 (listing images) ---
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_BUCKET="mullagain-listings"
# Optional CDN / public base URL in front of the bucket. If empty, the app
# falls back to the regional S3 URL.
S3_PUBLIC_BASE_URL=""

# --- Email (Resend) ---
RESEND_API_KEY=""
EMAIL_FROM="MullAgain <no-reply@mullagain.test>"

# --- SMS / phone verification (Twilio) ---
# Without these, OTP codes are logged to the server console (dev mode).
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
# Provide EITHER a from-number OR a Messaging Service SID.
TWILIO_FROM=""
TWILIO_MESSAGING_SERVICE_SID=""

# --- Rate limiting (Upstash Redis) ---
# Without these, an in-memory limiter is used (fine for a single instance / dev,
# but not across serverless instances). Create a Redis DB at upstash.com.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- Feature flags / policy ---
# If true, new sellers' listings must be approved by an admin before going live.
REQUIRE_LISTING_REVIEW_FOR_NEW_SELLERS="true"
# Listings at or above this price (in cents) always go to manual review.
HIGH_VALUE_REVIEW_THRESHOLD_CENTS="50000"
# Hours after delivery before an order auto-completes.
AUTO_COMPLETE_AFTER_DELIVERY_HOURS="72"
# Hours an accepted offer / reserved order stays valid before expiring.
OFFER_EXPIRY_HOURS="48"
